modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.development]
TELEGRAM_WEBHOOK_URL = "https://8ba42bad-bd93-4116-ab23-66e2fad22fb5-00-14ukjrywaq5z1.kirk.replit.dev/api/telegram/webhook"

[userenv.production]
TELEGRAM_WEBHOOK_URL = "https://margarita-go-ride-build.replit.app/api/telegram/webhook"
